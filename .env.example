# General Settings
# Base path for Docker persistent data
DOCKER_DATA_PATH=/path/to/docker_data
# Script directory (for rclone config, backup config, etc.)
SCRIPT_DIR=/path/to/script
# Backup destination directory
BACKUP_DIR=/path/to/backup
PUID=1000
PGID=100
TZ=Europe/Paris

# Internal server URL (without port)
SERVER_URL=http://your-server-ip

# Public URLs
NAVI_URL=https://your-navidrome-url.example.com
NAVI_INTERNAL_URL=http://navidrome:4533
AUDIOMUSEAI_INTERNAL_URL=http://audiomuse-ai-flask-app:8000
HA_URL=https://your-homeassistant-url.example.com

# AskNavidrome Configuration
# Port for AskNavidrome Alexa skill
ASKNAVIDROME_PORT=5000
NAVI_SKILL_ID=your_alexa_skill_id_here
NAVI_USER=your_navidrome_username
NAVI_PASS=your_navidrome_password

# AudioBookshelf Configuration
# Port for AudioBookshelf web interface
AUDIOBOOKSHELF_PORT=13378
# Media library paths
AUDIOBOOK_PATH=/path/to/audiobooks
EBOOK_PATH=/path/to/ebooks
PODCAST_PATH=/path/to/podcasts

# Home Assistant Configuration
# Home Assistant web interface port (default 8123, Matter Hub needs this for local connection)
HA_PORT=8124
# MQTT broker ports
MQTT_PORT=1883
MQTT_WEBSOCKET_PORT=9001

# Zigbee2MQTT web interface port
ZIGBEE2MQTT_PORT=8085

# ZwaveJS2MQTT ports
ZWAVEJS_WEB_PORT=8091
ZWAVEJS_WEBSOCKET_PORT=3000

# Access token for Home Assistant (create in your HA profile)
HAMH_HA_TOKEN=your_home_assistant_long_lived_token

# Session secret for ZwaveJS2MQTT (use a random string)
ZWAVE_SESSION_SECRET=your_random_secret_key_here

# Nginx Proxy Manager Configuration
# Reverse proxy ports (change only if already in use)
NPM_HTTP_PORT=80
NPM_ADMIN_PORT=81
NPM_HTTPS_PORT=443

# Portainer Configuration
# Docker management interface ports
PORTAINER_HTTP_PORT=9000
PORTAINER_HTTPS_PORT=9443

# Vaultwarden Configuration
# Password manager web interface port
VAULTWARDEN_PORT=8800

# Admin panel token (generate with: echo -n "your_password" | argon2 "$(openssl rand -base64 32)" -e -id -k 65540 -t 3 -p 4)
VW_ADMIN_TOKEN=your_argon2_hashed_admin_token

# SMTP settings for email notifications
VW_SMTP_FROM=your_email@gmail.com
VW_SMTP_PASSWORD=your_gmail_app_password

# WireGuard Configuration
# Public hostname or IP for WireGuard VPN access
WG_HOST=your-domain.example.com

# Web interface password hash (generate with: docker run -it ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD)
WG_PASSWORD_HASH=your_bcrypt_hashed_password

# Note: WireGuard uses network_mode: host
# Default ports: 51820 (VPN), 51821 (Web UI)

# Homepage Configuration
# Port for Homepage dashboard
HOMEPAGE_PORT=8008

# Comma-separated list of allowed hosts (IPs, domains, with/without ports)
HOMEPAGE_ALLOWED_HOSTS=localhost,your-ip:8008,your-domain.example.com

# Backup Services Configuration
# Backrest - Modern backup solution with web UI (uses restic)
BACKREST_PORT=9898

# Navidrome & Music Services Configuration
# Service ports
NAVIDROME_PORT=4533
AUDIOMUSEAI_PORT=8000
RECOMMAND_PORT=5005
DEEFIND_PORT=1234

# Path to your music library
MUSIC_PATH=/path/to/music

# Navidrome credentials
NAVIDROME_USER=your_username
NAVIDROME_PASSWORD=your_password

# Spotify API credentials (get from https://developer.spotify.com)
ND_SPOTIFY_ID=your_spotify_client_id
ND_SPOTIFY_SECRET=your_spotify_client_secret

# Last.fm API credentials (get from https://www.last.fm/api)
ND_LASTFM_APIKEY=your_lastfm_api_key
ND_LASTFM_SECRET=your_lastfm_secret

# Deezer ARL token (for deefind/deemix integration)
DEEMIX_ARL=your_deezer_arl_token

# AudioMuse Configuration
# Database and cache ports
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database credentials
POSTGRES_USER=audiomuse
POSTGRES_PASSWORD=your_secure_password
